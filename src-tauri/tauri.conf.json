{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenList Explorer",
  "version": "0.1.4",
  "identifier": "com.openlist.explorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenList Explorer",
        "width": 1180,
        "height": 760,
        "minWidth": 1040,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/openlist"]
  }
}
